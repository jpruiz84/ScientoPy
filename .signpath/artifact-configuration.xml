<?xml version="1.0" encoding="utf-8" ?>
<!--
  SignPath artifact configuration for ScientoPy (Windows build).

  The build job uploads dist/ScientoPyGui/ as a directory artifact.
  GitHub creates a single ZIP from that directory, so SignPath receives
  a ZIP with ScientoPyGui.exe and _internal/ directly at the root.

  Reference: https://about.signpath.io/documentation/artifact-configuration/
-->
<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">
  <zip-file>
    <pe-file path="ScientoPyGui.exe">
      <authenticode-sign />
    </pe-file>
  </zip-file>
</artifact-configuration>
